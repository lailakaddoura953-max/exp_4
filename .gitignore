runs/

# Private/sensitive config
# NOTE: ip_addresses_template.json is intentionally NOT ignored — it only
# contains placeholder values and needs to be copied to ip_addresses.json
# (which IS ignored) on each machine that connects to a real camera.
config/ip_addresses.json
